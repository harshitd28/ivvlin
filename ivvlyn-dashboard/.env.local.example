# Copy to .env.local (never commit .env.local)

# App + browser (public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only — webhooks, enqueue, internal cron, worker:outbound
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Supabase CLI (`supabase gen types`, Management API). Not required for the Next app.
# SUPABASE_ACCESS_TOKEN=

# Required for `npm run db:link` then `npm run db:push` (database password from Supabase → Settings → Database)
# SUPABASE_DB_PASSWORD=

# Meta WhatsApp webhook (production)
# META_VERIFY_TOKEN=
# META_APP_SECRET=

# Internal cron / queue routes (`Authorization: Bearer …`)
# CRON_SECRET=

# n8n / workflows → POST /api/internal/ingest/whatsapp (`Authorization: Bearer …`)
# INTERNAL_INGEST_SECRET=

# Optional: Bearer / shared header for `POST /webhook/takeover-handler`
# WEBHOOK_SHARED_SECRET=

# Dev: bypass WhatsApp 24h session check on `POST /api/messaging/outbound/enqueue` (do not use in production)
# WHATSAPP_SKIP_SESSION_WINDOW=1

# Optional — when set, Meta webhook POST is rate-limited per caller IP (see META_WEBHOOK_RATE_PER_MIN)
# REDIS_URL=
# META_WEBHOOK_RATE_PER_MIN=400
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
